# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Use mock API for development (set to "false" to use real API)
VITE_USE_MOCK_API=true

# Printer Configuration (optional)
# Set these to match your printer names in the system
RECEIPT_PRINTER=Thermal Printer
STICKER_PRINTER=Label Printer

# Kiosk Configuration
# Idle timeout before showing ads (in seconds)
# Default: 1800 seconds (30 minutes)
VITE_IDLE_TIMEOUT=1800

# Development
VITE_DEV_SERVER_URL=http://localhost:5173
